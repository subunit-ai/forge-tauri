{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "u1 Forge",
  "version": "0.1.0",
  "identifier": "ai.subunit.forge",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "u1 Forge",
        "width": 800,
        "height": 600
      },
      {
        "label": "overlay",
        "title": "u1 arbeitet",
        "url": "index.html",
        "fullscreen": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "focus": false,
        "focusable": false,
        "visible": false,
        "shadow": false
      },
      {
        "label": "overlayControl",
        "title": "Forge Overlay",
        "url": "index.html",
        "width": 170,
        "height": 46,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "visible": false,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/subunit-bridge"],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "longDescription": "u1 Forge — Remote-Support. Bündelt die Subunit Bridge als Sidecar (ein Paket).",
    "shortDescription": "u1 Forge (Remote-Support)"
  }
}
