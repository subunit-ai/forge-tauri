{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for Forge status, overlay, and tray-facing windows",
  "windows": ["main", "overlay", "overlayControl"],
  "permissions": [
    "core:default",
    "core:window:allow-set-ignore-cursor-events",
    "opener:default",
    "autostart:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/subunit-bridge",
          "sidecar": true,
          "args": false
        }
      ]
    }
  ]
}
